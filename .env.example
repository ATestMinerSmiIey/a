# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Username-only login: each user is stored in Supabase Auth as <username>@<domain>.
# Use a non-routable / internal domain you control (not a real mailbox). Must stay in sync
# with accounts you create; never commit real passwords to the repo or frontend.
# Validator-friendly synthetic domain (Supabase/Lovable often rejects .internal)
VITE_AUTH_EMAIL_DOMAIN="example.com"

# Optional: maintainer-only auth setup checklist + env-hint toasts (default off everywhere)
# VITE_SHOW_AUTH_SETUP_HELP=true

# Optional: show raw API error text in save toasts (default off; use browser console instead)
# VITE_VERBOSE_API_ERRORS=true

# One-time auth seed (npm run seed:auth) — set passwords only in your shell or a local untracked file; never commit.
# SUPABASE_SERVICE_ROLE_KEY must be the service_role key from the Supabase dashboard.
# AUTH_EMAIL_DOMAIN should match VITE_AUTH_EMAIL_DOMAIN.
# SEED_USER_PASSWORD=
# SEED_ADMIN_PASSWORD=

# Edge function order-assign-tracking: set in Supabase (Dashboard → Edge Functions → Secrets), not in Vite:
# TRACK17_TOKEN=<your 17TRACK API key>
